## Runtime environment: development | production
ENVIRONMENT=development
## Enable verbose error messages and auto-reload in dev
DEBUG=true
## Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
## Network bind host
HOST=0.0.0.0
## API port
PORT=8000

## Database Configuration
## Async SQLAlchemy DSN (default: SQLite file under data/)
DATABASE_URL=postgresql+asyncpg://maas_user:maas_local_pass@localhost:5432/maas_backend

## JWT Authentication
## HMAC secret for JWT signing (change in production)
SECRET_KEY=your-super-secret-key-change-this-in-production
## Access token TTL in minutes (short-lived; clients refresh via cookie)
ACCESS_TOKEN_EXPIRE_MINUTES=15
## Separate HMAC secret for refresh JWT signing (change in production)
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-in-production
## Remember-me refresh token TTL in days
REFRESH_TOKEN_EXPIRE_DAYS=30
## Non-persistent browser-session refresh token server-side cap in minutes
REFRESH_TOKEN_EXPIRE_MINUTES_SESSION=720
## Refresh token cookie settings
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/
## Leave unset for host-only cookies; set only when sharing across subdomains
#REFRESH_COOKIE_DOMAIN=.example.com
## Use true in production HTTPS; set false only for local HTTP development
REFRESH_COOKIE_SECURE=true
## Use lax/strict for same-site apps; cross-site SPAs require none + Secure + explicit CORS origins
REFRESH_COOKIE_SAMESITE=lax

## Admin User Configuration
## Initial admin login; password must be changed on first login
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin
## New admin password used in tests/utilities
ADMIN_NEW_PASSWORD=admin123

## Test Configuration (used by helper scripts)
TEST_USERNAME=testuser
TEST_USER_PASSWORD=testpass123

## File Upload Configuration
## Maximum upload size in bytes (50MB)
MAX_FILE_SIZE=52428800
## Persistent uploads directory
UPLOAD_DIR=./uploads/3d_models
## Temporary working directory
TEMP_DIR=./uploads/temp

## Document Upload Configuration
## Maximum document upload size in bytes (100MB)
MAX_DOCUMENT_SIZE=104857600
## Documents storage directory
DOCUMENTS_DIR=./uploads/documents

## CORS Configuration
## Allowed origins as JSON array
CORS_ORIGINS=["*"]
## Allow sending credentials (cookies/authorization headers)
CORS_ALLOW_CREDENTIALS=true
## Production cookie auth requires explicit origins, not wildcard, when credentials are enabled
## Allowed methods and headers as JSON arrays
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

## Logging Configuration
## Python logging format
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

## Bitrix24 Integration
## Master switch for Bitrix integration
BITRIX_ENABLED=true
## Incoming webhook base URL (ends with /rest/<user>/<token>/)
BITRIX24_WEBHOOK_URL=https://192.168.21.75/rest/1/qfty5cwm8zuwlzil/
## Verify TLS certificates (set false for LAN/self-signed)
BITRIX_VERIFY_TLS=false
## MaaS Funnel Configuration
## Name of the MaaS sales funnel in Bitrix (default: MaaS)
BITRIX_MAAS_FUNNEL_NAME=MaaS
## MaaS funnel category ID (optional, auto-detected if not set)
#BITRIX_MAAS_CATEGORY_ID=

## Email verification (registration)
EMAIL_VERIFICATION_ENABLED=true
# Token lifetime in seconds (default 24h)
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
# Frontend URL with {token} placeholder
EMAIL_VERIFICATION_CONFIRM_URL_TEMPLATE=https://app.example.com/confirm-email?token={token}
# Min seconds between sends for the same email (idempotency)
EMAIL_VERIFICATION_SEND_COOLDOWN_SECONDS=300
EMAIL_VERIFICATION_RATE_LIMIT_PER_EMAIL=3
EMAIL_VERIFICATION_RATE_LIMIT_PER_IP=20
EMAIL_VERIFICATION_RATE_LIMIT_WINDOW_SECONDS=3600
EMAIL_VERIFICATION_BITRIX_SUBJECT=Подтверждение электронной почты
EMAIL_VERIFICATION_BITRIX_MESSAGE_FROM=service.bitrix24 <service.bitrix24@kronshtadt.ru>
EMAIL_VERIFICATION_BITRIX_RESPONSIBLE_ID=1
# If true, do not issue a token when Bitrix contact mapping is missing
EMAIL_VERIFICATION_REQUIRE_BITRIX_CONTACT=true

## Password recovery (forgot password)
PASSWORD_RECOVERY_ENABLED=true
# Token lifetime in seconds (default 1h)
PASSWORD_RECOVERY_TOKEN_TTL_SECONDS=3600
# Frontend URL with {token} placeholder
PASSWORD_RECOVERY_RESET_URL_TEMPLATE=https://app.example.com/reset-password?token={token}
# Min seconds between sends for the same email (idempotency)
PASSWORD_RECOVERY_SEND_COOLDOWN_SECONDS=300
PASSWORD_RECOVERY_RATE_LIMIT_PER_EMAIL=3
PASSWORD_RECOVERY_RATE_LIMIT_PER_IP=20
PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_SECONDS=3600
PASSWORD_RECOVERY_BITRIX_SUBJECT=Восстановление пароля
PASSWORD_RECOVERY_BITRIX_MESSAGE_FROM=service.bitrix24 <service.bitrix24@kronshtadt.ru>
PASSWORD_RECOVERY_BITRIX_RESPONSIBLE_ID=1
# If true, do not issue a token when Bitrix contact mapping is missing
PASSWORD_RECOVERY_REQUIRE_BITRIX_CONTACT=true

# Second backend for calculations
#STL_SERVER_URL=http://mdgkd-vlabal.int.kronshtadt.ru:7000/calculate/cnc
# Base calculator service URL - specific endpoints will be appended dynamically based on service type
CALCULATOR_BASE_URL=http://localhost:7000/calculate
